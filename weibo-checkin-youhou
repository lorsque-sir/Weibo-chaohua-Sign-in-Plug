// @updateURL    https://update.greasyfork.org/scripts/390039/%E5%BE%AE%E5%8D%9A%E8%B6%85%E8%AF%9D%E8%87%AA%E5%8A%A8%E7%AD%BE%E5%88%B0.meta.js
